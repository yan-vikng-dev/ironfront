set shell := ["bash", "-euo", "pipefail", "-c"]

env_dir := source_directory()

fix:
	pnpm run fix

dev:
	set -a; source "{{env_dir}}/.env.dev" 2>/dev/null || true; set +a; pnpm run dev

migrate:
	set -a; source "{{env_dir}}/.env.dev" 2>/dev/null || true; set +a; pnpm run db:push

studio:
	set -a; source "{{env_dir}}/.env.dev" 2>/dev/null || true; set +a; pnpm run db:studio
